# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ── Admin ─────────────────────────────────────────────
ADMIN_PASSWORD=kingdomkids-admin

# ── MFA (TOTP) — run: node scripts/setup-mfa.js ───────
# Leave unset to disable MFA (password-only login)
ADMIN_TOTP_SECRET=

# ── Stripe (get from dashboard.stripe.com → Developers → API Keys) ──
STRIPE_SECRET_KEY=sk_live_...

# ── Resend email (get from resend.com → API Keys) ─────
RESEND_API_KEY=re_...

# ── PDF download token signing (any random string) ────
DOWNLOAD_SECRET=make-this-a-long-random-string

# ── Site URL (used for Stripe redirect URLs) ──────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
